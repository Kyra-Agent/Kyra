{
  "name": "kyra-agent",
  "description": "Robinhood Chain AI agent platform with approval-first onchain workflows.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://kyraagent.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kyra-Agent/Kyra.git"
  },
  "keywords": [
    "robinhood-chain",
    "onchain",
    "ai-agent",
    "supabase",
    "telegram-bot",
    "vite",
    "react",
    "typescript",
    "web3"
  ],
  "scripts": {
    "dev": "vite --host localhost",
    "dev:robinhood-testnet": "vite --mode robinhood-testnet --host localhost",
    "dev:robinhood-mainnet": "vite --mode robinhood-mainnet --host localhost",
    "test:wallet-signing": "node scripts/test-wallet-signing-state.mjs",
    "test:wallet-prompt-eligibility": "node scripts/test-wallet-prompt-eligibility.mjs",
    "test:prepared-action-allowlist": "node scripts/test-prepared-action-allowlist.mjs",
    "test:prepared-action-policy": "node scripts/test-prepared-action-policy.mjs",
    "test:dual-approval-execution": "node scripts/test-dual-approval-execution.mjs",
    "test:result-monitoring-closeout": "node scripts/test-result-monitoring-closeout.mjs",
    "test:controlled-live-transaction-gate": "node scripts/test-controlled-live-transaction-gate.mjs",
    "test:execution-launch-readiness": "node scripts/test-execution-launch-readiness.mjs",
    "test:phase-8": "node scripts/test-phase-8-controlled-execution.mjs",
    "test:phase-8-live-window": "node scripts/test-phase-8-live-window-preparation.mjs",
    "test:phase-8-wallet-prompt": "node scripts/test-phase-8-wallet-prompt-opening.mjs",
    "test:phase-8-submission": "node scripts/test-phase-8-controlled-submission.mjs",
    "test:phase-8-owner-submit-request": "node scripts/test-phase-8-owner-submit-request.mjs",
    "test:phase-8-submitter-closeout": "node scripts/test-phase-8-submitter-closeout.mjs",
    "test:phase-8-result-persistence": "node scripts/test-phase-8-result-persistence.mjs",
    "test:owner-wallet-connection": "node scripts/test-owner-wallet-connection.mjs",
    "check:owner-wallet-migration": "npm run test:owner-wallet-connection && node scripts/check-owner-wallet-migration.mjs",
    "test:unsigned-handoff": "node scripts/test-unsigned-transaction-handoff.mjs",
    "test:risk-review": "node scripts/test-risk-review.mjs",
    "test:execution-result": "node scripts/test-execution-result.mjs",
    "check:functions": "node scripts/check-functions.mjs",
    "check:privacy": "node scripts/check-public-privacy.mjs",
    "check:execution-launch-readiness": "npm run test:execution-launch-readiness && node scripts/check-controlled-execution-launch-packet.mjs",
    "test:phase-8-owner-live-window-activation": "node scripts/test-phase-8-owner-live-window-activation.mjs",
    "test:phase-8-owner-action-candidate": "node scripts/test-phase-8-owner-action-candidate.mjs",
    "test:phase-8-runtime-preflight": "node scripts/test-phase-8-runtime-enable-preflight.mjs",
    "check:roadmap": "node scripts/check-product-phase-roadmap.mjs",
    "build": "tsc && vite build",
    "build:robinhood-testnet": "tsc && vite build --mode robinhood-testnet",
    "build:robinhood-mainnet": "tsc && vite build --mode robinhood-mainnet",
    "preview": "vite preview --host localhost",
    "test:phase-8-funding-readiness": "node scripts/test-phase-8-funding-readiness.mjs",
    "test:phase-8-smoke-closeout": "node scripts/test-phase-8-smoke-closeout.mjs",
    "test:phase-8-user-safe-policy": "node scripts/test-phase-8-user-safe-transaction-policy.mjs",
    "test:phase-8-low-value-readiness": "node scripts/test-phase-8-low-value-transaction-readiness.mjs",
    "test:phase-8-low-value-submit-request": "node scripts/test-phase-8-low-value-submit-request.mjs",
    "test:phase-8-low-value-submitter": "node scripts/test-phase-8-low-value-submitter-gate.mjs",
    "test:phase-8-transaction-verification": "node scripts/test-phase-8-transaction-verification.mjs",
    "test:phase-8-user-execution-flow": "node scripts/test-phase-8-user-execution-flow.mjs",
    "test:phase-8-security-abuse-hardening": "node scripts/test-phase-8-security-abuse-hardening.mjs",
    "test:phase-8-production-closeout": "node scripts/test-phase-8-production-closeout.mjs",
    "test:phase-9a-execution-eligibility": "node scripts/test-phase-9a-execution-eligibility.mjs",
    "test:phase-9b-abuse-rate-limit": "node scripts/test-phase-9b-abuse-rate-limit.mjs",
    "test:phase-9c-incident-controls": "node scripts/test-phase-9c-incident-controls.mjs",
    "test:phase-9d-monitoring-support": "node scripts/test-phase-9d-monitoring-support.mjs",
    "test:phase-9e-public-privacy-release": "node scripts/test-phase-9e-public-privacy-release.mjs",
    "test:phase-9-closeout": "node scripts/test-phase-9-closeout.mjs",
    "check:product-snapshot": "node scripts/check-product-readiness-snapshot.mjs",
    "test:product-chains": "node scripts/test-product-chain-registry.mjs",
    "check:chain-abstraction": "npm run test:product-chains && node scripts/check-product-chain-abstraction.mjs",
    "check:robinhood-testnet-lane": "npm run test:robinhood-testnet-closeout && node scripts/check-robinhood-testnet-lane.mjs",
    "test:robinhood-testnet-closeout": "node scripts/test-robinhood-testnet-closeout.mjs",
    "check:agent-chain-binding": "node scripts/check-agent-chain-binding.mjs",
    "check:robinhood-migration": "npm run check:robinhood-only && node scripts/check-robinhood-chain-migration-blueprint.mjs && npm run check:chain-abstraction && npm run check:owner-wallet-migration && npm run check:chain-backend && npm run check:robinhood-testnet-lane && npm run check:agent-chain-binding && npm run check:robinhood-mainnet-cutover",
    "check:robinhood-mainnet-cutover": "node scripts/check-robinhood-mainnet-cutover.mjs",
    "check:robinhood-public-cutover": "node scripts/check-robinhood-public-cutover.mjs",
    "test:chain-backend": "node scripts/run-chain-backend-tests.mjs",
    "check:chain-backend": "npm run test:chain-backend && deno check supabase/functions/chain-status-provider/index.ts supabase/functions/chain-action-prepare/index.ts && node scripts/check-robinhood-chain-backend.mjs",
    "test:execution-safety": "npm run test:wallet-signing && npm run test:wallet-prompt-eligibility && npm run test:prepared-action-allowlist && npm run test:prepared-action-policy && npm run test:risk-review && npm run test:controlled-live-transaction-gate && npm run test:execution-result",
    "check:launch-packet": "node scripts/check-controlled-execution-launch-packet.mjs",
    "check:product": "npm run check:privacy && npm run check:functions && npm run check:prepared-actions && npm run check:robinhood-migration && npm run check:robinhood-public-cutover && npm run check:roadmap && npm run check:product-snapshot && npm run check:launch-packet && npm run test:execution-safety",
    "check:prepared-actions": "npm run test:unsigned-handoff && npm run test:prepared-action-allowlist && npm run test:prepared-action-policy && npm run test:risk-review",
    "test:all": "node scripts/run-all-tests.mjs",
    "check:robinhood-only": "node scripts/check-robinhood-only-repository.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.52.2",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.3"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
