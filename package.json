{
  "name": "kyra-agent",
  "description": "Base-native onchain agent console demo.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://kyraagent.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kyra-Agent/Kyra.git"
  },
  "keywords": [
    "base",
    "onchain",
    "ai-agent",
    "supabase",
    "telegram-bot",
    "mcp",
    "vite",
    "react",
    "typescript",
    "web3"
  ],
  "scripts": {
    "dev": "vite --host localhost",
    "check:phase-6b": "node scripts/check-phase-6b-review-packet.mjs",
    "check:phase-6c": "node scripts/check-phase-6c-wallet-handoff.mjs",
    "test:wallet-signing": "node scripts/test-wallet-signing-state.mjs",
    "test:unsigned-handoff": "node scripts/test-unsigned-transaction-handoff.mjs",
    "test:risk-review": "node scripts/test-risk-review.mjs",
    "test:execution-result": "node scripts/test-execution-result.mjs",
    "check:base-mcp": "node scripts/check-base-mcp-contract.mjs",
    "check:functions": "node scripts/check-functions.mjs",
    "check:prepared-actions": "node scripts/check-prepared-action-boundary.mjs",
    "check:privacy": "node scripts/check-public-privacy.mjs",
    "check:supabase-copy": "node scripts/check-supabase-catalog-copy.mjs",
    "check:phase-7-entry": "node scripts/check-phase-7-entry.mjs",
    "check:phase-7b": "node scripts/check-phase-7b-ownership.mjs",
    "check:phase-7": "npm run check:phase-6 && npm run check:phase-7-entry && npm run check:phase-7b",
    "check:phase-6": "npm run check:privacy && npm run check:base-mcp && npm run check:prepared-actions && npm run check:supabase-copy && npm run check:phase-6b && npm run check:phase-6c && npm run test:unsigned-handoff && npm run test:wallet-signing && npm run test:risk-review && npm run test:execution-result && npm run check:functions",
    "build": "tsc && vite build",
    "preview": "vite preview --host localhost"
  },
  "dependencies": {
    "@base-org/account": "^2.5.6",
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.52.2",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.2"
  }
}
